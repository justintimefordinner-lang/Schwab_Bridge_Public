# Copy this file to ".env". It holds NON-secret configuration and refresh
# intervals only. Your Schwab App Key and Secret do NOT belong here — set them
# once from the dashboard's Settings page (it writes them, write-only, into
# credentials.env), or copy credentials.env.example to credentials.env yourself.

# Must EXACTLY match the callback URL registered on your Schwab app.
# For local development, 127.0.0.1 is what Schwab expects.
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182

# Where the cached OAuth token is stored. Keep this out of version control.
SCHWAB_TOKEN_PATH=token.json

# Absolute path to the dashboard app's data/ folder the bridge writes into.
#   Windows example:      C:\path\to\Trading_Dashboard_App\data
#   Raspberry Pi example: /home/<user>/Trading_Dashboard_App/data
APP_DATA_DIR=./data

# How often (seconds) each pusher runs.
APP_PUSH_INTERVAL=60
