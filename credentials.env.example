# Copy this file to "credentials.env" and fill in your Schwab app credentials —
# OR just enter them once on the dashboard's Settings page, which writes this
# file for you (write-only: the app deposits them here and never reads them
# back). Get these from your app page at https://developer.schwab.com/dashboard/apps
#
# This file holds SECRETS. It is git-ignored; keep it chmod 600. Values here
# override anything of the same name in .env.

SCHWAB_API_KEY=Enter Here
SCHWAB_APP_SECRET=Enter Here
