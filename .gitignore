# ─── Secrets — never commit these ───────────────────────────────
.env
.env.*
credentials.env
credentials.env.*
token.json
tokens.json
client_secret*.json
credentials*.json
*.pem
*.pickle
*.pkl

# ─── Re-auth (write-only) transient files — never commit ────────
.auth_state.json
reauth_inbox/

# ─── Committable templates (re-include these; must come after the rules above) ───
!.env.example
!credentials.env.example

# ─── Logs / scratch ─────────────────────────────────────────────
export_log.txt
*.log

# ─── Python ─────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# ─── Virtualenvs ────────────────────────────────────────────────
.venv/
.venv*
venv/

# ─── OS junk ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
